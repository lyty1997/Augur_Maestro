# Augur_Maestro local environment example.
# Copy values into a private .env file when needed. Never commit real secrets or account data.

AUGUR_MAESTRO_ENV=local
AUGUR_MAESTRO_LOG_LEVEL=INFO

# PostgreSQL is introduced by the M1 database task. Keep placeholders non-sensitive.
AUGUR_MAESTRO_DATABASE_HOST=localhost
AUGUR_MAESTRO_DATABASE_PORT=5432
AUGUR_MAESTRO_DATABASE_NAME=augur_maestro
AUGUR_MAESTRO_DATABASE_USER=augur_maestro

# Broker credentials must stay out of Git. Real trading remains disabled by default.
AUGUR_MAESTRO_BROKER_MODE=read_only
AUGUR_MAESTRO_TRADING_ENABLED=false
