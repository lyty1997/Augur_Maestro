# RobustQuant local environment example.
# Copy values into a private .env file when needed. Never commit real secrets or account data.

ROBUSTQUANT_ENV=local
ROBUSTQUANT_LOG_LEVEL=INFO

# PostgreSQL is introduced by the M1 database task. Keep placeholders non-sensitive.
ROBUSTQUANT_DATABASE_HOST=localhost
ROBUSTQUANT_DATABASE_PORT=5432
ROBUSTQUANT_DATABASE_NAME=robustquant
ROBUSTQUANT_DATABASE_USER=robustquant

# Broker credentials must stay out of Git. Real trading remains disabled by default.
ROBUSTQUANT_BROKER_MODE=read_only
ROBUSTQUANT_TRADING_ENABLED=false
